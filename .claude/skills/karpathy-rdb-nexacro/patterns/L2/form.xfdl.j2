<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.0">
<Form id="{{ form_id }}" width="900" height="620" titletext="{{ title }}">
  <Layout>
    <!-- Search panel (top) -->
    <Static id="ttl_search" left="10" top="6" width="120" height="20" text="검색조건" cssclass="sta_WF_Title"/>
    {{ search_fields | indent(4) }}
    <Button id="btn_search" left="310" top="20" width="80" height="24" text="조회" onclick="fn_search"/>

    <!-- Left: list grid (0..400) -->
    <Grid id="grd_list" left="10" top="70" width="380" height="500"
          binddataset="ds{{ entity_pascal }}" autofittype="col" useinputpanel="false"
          oncellclick="fn_grid_click">
{{ grid_format | indent(6) }}
    </Grid>
    <Button id="btn_add"  left="220" top="580" width="80" height="28" text="추가" onclick="fn_add"/>
    <Button id="btn_del"  left="310" top="580" width="80" height="28" text="삭제" onclick="fn_delete"/>

    <!-- Divider -->
    <Static id="div_v" left="400" top="70" width="1" height="500" cssclass="sta_WF_Divider"/>

    <!-- Right: detail edit panel (410..890) -->
    <!-- detail bind는 grid와 동일 dataset(ds{{ entity_pascal }})의 rowposition을 따른다. -->
    <Static id="ttl_detail" left="410" top="70" width="120" height="20" text="상세" cssclass="sta_WF_Title"/>
    <Static id="hint_detail" left="410" top="100" width="480" height="40"
            text="grid 행을 선택하면 detail 영역이 자동 갱신됩니다. 필드별 Edit 컴포넌트는 form 사용자가 columns에 맞춰 보강 권장."
            cssclass="sta_WF_Hint" wordWrap="char"/>
    <Button id="btn_save" left="800" top="580" width="80" height="28" text="저장" onclick="fn_save"/>
  </Layout>

  <Objects>
{{ datasets | indent(4) }}
  </Objects>

  <Script type="xscript5.1"><![CDATA[
this.fn_search = function() {
  this.transaction("select",
    "Svc{{ service_pascal }}::{{ select_path }}",
    "dsSearch=dsSearch",
    "output1=ds{{ entity_pascal }}",
    "", "fn_callback");
};

this.fn_grid_click = function(obj, e) {
  // rowposition follows automatically; detail edits bound to same dataset
};

this.fn_add = function() {
  var n = this.ds{{ entity_pascal }}.addRow();
  this.grd_list.setCellPos(0);
};

this.fn_delete = function() {
  var r = this.ds{{ entity_pascal }}.rowposition;
  if (r < 0) return;
  this.ds{{ entity_pascal }}.deleteRow(r);
};

this.fn_save = function() {
  if (this.ds{{ entity_pascal }}.getRowCountNF() === 0) {
    alert("저장할 행이 없습니다.");
    return;
  }
  this.transaction("save",
    "Svc{{ service_pascal }}::{{ save_path }}",
    "",
    "",
    "dataList=ds{{ entity_pascal }}:U",
    "fn_callback");
};

this.fn_callback = function(svcId, errCd, errMsg) {
  if (errCd < 0) { alert(errMsg); return; }
  if (svcId === "save") this.fn_search();
};
  ]]></Script>
</Form>
</FDL>
