<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.0">
<Form id="popupSearch{{ entity_pascal }}" classname="Popup" titletext="{{ title }} 검색"
      left="0" top="0" width="800" height="500" onload="form_onload">
  <Layout>
    <!-- Search bar -->
    <Static id="ttl_search" left="10" top="6" width="120" height="20" text="검색조건" cssclass="sta_WF_Title"/>
    {{ search_fields | indent(4) }}
    <Button id="btn_search" left="310" top="20" width="80" height="24" text="조회" onclick="fn_search"/>

    <!-- Result grid: double-click to return -->
    <Grid id="grd_result" left="10" top="60" width="780" height="380"
          binddataset="ds{{ entity_pascal }}" autofittype="col" readonly="true"
          oncelldblclick="fn_select_row">
{{ grid_format | indent(6) }}
    </Grid>

    <!-- Action buttons -->
    <Button id="btn_select" right="100" bottom="10" width="80" height="32" text="선택" onclick="fn_select_row"/>
    <Button id="btn_cancel" right="10"  bottom="10" width="80" height="32" text="취소" onclick="fn_close"/>
  </Layout>

  <Objects>
{{ datasets | indent(4) }}
  </Objects>

  <Script type="xscript5.1"><![CDATA[
this.form_onload = function(obj, e) {
  // opener에서 전달한 초기 검색조건 dsSearch에 prepopulate (있을 경우)
  var args = this.getOwnerFrame ? this.getOwnerFrame().arguments : null;
  if (args) {
    for (var key in args) {
      try { this.dsSearch.setColumn(0, key, args[key]); } catch (ex) {}
    }
  }
  this.fn_search();
};

this.fn_search = function() {
  this.transaction("select",
    "Svc{{ service_pascal }}::{{ select_path }}",
    "dsSearch=dsSearch",
    "output1=ds{{ entity_pascal }}",
    "", "fn_callback");
};

this.fn_select_row = function() {
  var r = this.ds{{ entity_pascal }}.rowposition;
  if (r < 0) { alert("선택할 행이 없습니다."); return; }

  // 선택된 row의 모든 컬럼을 객체로 묶어 opener.fnReceivePopupData 호출
  var oData = {};
  var ds = this.ds{{ entity_pascal }};
  for (var c = 0; c < ds.getColCount(); c++) {
    var colId = ds.getColID(c);
    oData[colId] = ds.getColumn(r, colId);
  }

  var opener = this.opener || (this.getOwnerFrame && this.getOwnerFrame().opener);
  if (opener && typeof opener.fnReceivePopupData === "function") {
    opener.fnReceivePopupData(oData);
  }
  this.fn_close();
};

this.fn_close = function() {
  if (this.getOwnerFrame) this.getOwnerFrame().close();
};

this.fn_callback = function(svcId, errCd, errMsg) {
  if (errCd < 0) { alert(errMsg); return; }
};
  ]]></Script>
</Form>
</FDL>
