<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.0">
<Form id="{{ form_id }}" width="1000" height="640" titletext="{{ title }}">
  <Layout>
    <!-- Search panel (top) -->
    <Static id="ttl_search" left="10" top="6" width="120" height="20" text="검색조건" cssclass="sta_WF_Title"/>
    {{ search_fields | indent(4) }}
    <Button id="btn_search" left="310" top="20" width="80" height="24" text="조회" onclick="fn_search"/>

    <!-- Left: Category navigation (240px) -->
    <Static id="ttl_tree" left="10" top="60" width="220" height="20" text="카테고리" cssclass="sta_WF_Title"/>
    <Grid id="grd_tree" left="10" top="86" width="220" height="520"
          binddataset="dsCategory" autofittype="col" treeinitstatus="expand,null"
          onselchanged="fn_category_selected">
      <Formats>
        <Format id="default">
          <Columns>
            <Column size="220"/>
          </Columns>
          <Rows><Row size="28"/><Row size="28"/></Rows>
          <Band id="head"><Cell col="0" text="카테고리"/></Band>
          <Band id="body"><Cell col="0" text="bind:name" displaytype="treeitemcontrol" treelevel="bind:depth"/></Band>
        </Format>
      </Formats>
    </Grid>

    <!-- Right: Detail grid (rest) -->
    <Static id="ttl_detail" left="240" top="60" width="200" height="20" text="목록" cssclass="sta_WF_Title"/>
    <Grid id="grd_detail" left="240" top="86" width="750" height="490"
          binddataset="ds{{ entity_pascal }}" autofittype="col" useinputpanel="true">
{{ grid_format | indent(6) }}
    </Grid>
    <Button id="btn_add"  right="180" bottom="5" width="80" height="28" text="추가" onclick="fn_add"/>
    <Button id="btn_del"  right="90"  bottom="5" width="80" height="28" text="삭제" onclick="fn_delete"/>
    <Button id="btn_save" right="0"   bottom="5" width="80" height="28" text="저장" onclick="fn_save"/>
  </Layout>

  <Objects>
{{ datasets | indent(4) }}
    <!-- 좌측 카테고리: 호출 측에서 채워주거나, 도메인 별 별도 endpoint로 로드 -->
    <Dataset id="dsCategory">
      <ColumnInfo>
        <Column id="id"    type="STRING" size="64"/>
        <Column id="name"  type="STRING" size="120"/>
        <Column id="depth" type="INT"/>
      </ColumnInfo>
    </Dataset>
  </Objects>

  <Script type="xscript5.1"><![CDATA[
this.fn_search = function() {
  this.transaction("select",
    "Svc{{ service_pascal }}::{{ select_path }}",
    "dsSearch=dsSearch",
    "output1=ds{{ entity_pascal }}",
    "", "fn_callback");
};

this.fn_category_selected = function(obj, e) {
  // 좌측 카테고리 선택 → 우측 grid 재조회
  var r = this.dsCategory.rowposition;
  if (r < 0) return;
  var cat_id = this.dsCategory.getColumn(r, "id");
  this.dsSearch.setColumn(0, "{{ category_fk_column|default('category_id') }}", cat_id);
  this.fn_search();
};

this.fn_add = function() {
  var nr = this.ds{{ entity_pascal }}.addRow();
  // 현재 선택된 카테고리 자동 적용
  var r = this.dsCategory.rowposition;
  if (r >= 0) {
    this.ds{{ entity_pascal }}.setColumn(nr, "{{ category_fk_column|default('category_id') }}", this.dsCategory.getColumn(r, "id"));
  }
};

this.fn_delete = function() {
  var r = this.ds{{ entity_pascal }}.rowposition;
  if (r < 0) return;
  this.ds{{ entity_pascal }}.deleteRow(r);
};

this.fn_save = function() {
  if (this.ds{{ entity_pascal }}.getRowCountNF() === 0) { alert("저장할 행이 없습니다."); return; }
  this.transaction("save",
    "Svc{{ service_pascal }}::{{ save_path }}",
    "",
    "",
    "dataList=ds{{ entity_pascal }}:U",
    "fn_callback");
};

this.fn_callback = function(svcId, errCd, errMsg) {
  if (errCd < 0) { alert(errMsg); return; }
  if (svcId === "save") this.fn_search();
};
  ]]></Script>
</Form>
</FDL>
