<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.0">
<Form id="{{ form_id }}" width="1024" height="700" titletext="{{ title }}">
  <Layout>
    <!-- Search bar (목록 모드) -->
    <Static id="ttl_search" left="10" top="6" width="120" height="20" text="검색조건" cssclass="sta_WF_Title"/>
    {{ search_fields | indent(4) }}
    <Button id="btn_search" left="310" top="20" width="80" height="24" text="조회" onclick="fn_search"/>

    <!-- Master(header) list grid: row 선택 시 detail header + lines 모두 로드 -->
    <Static id="ttl_master" left="10" top="60" width="120" height="20" text="문서 목록" cssclass="sta_WF_Title"/>
    <Grid id="grd_master" left="10" top="86" width="1004" height="180"
          binddataset="ds{{ entity_pascal }}" autofittype="col" useinputpanel="false"
          onselchanged="fn_master_selected">
{{ grid_format | indent(6) }}
    </Grid>

    <!-- Detail Header (단일 row, Form-style BindItem 사용) -->
    <Static id="ttl_header" left="10" top="276" width="120" height="20" text="헤더" cssclass="sta_WF_Title"/>
    {{ header_fields | indent(4) }}

    <!-- Detail Lines (child grid) -->
    <Static id="ttl_lines" left="10" top="420" width="120" height="20" text="라인" cssclass="sta_WF_Title"/>
    <Grid id="grd_lines" left="10" top="446" width="1004" height="160"
          binddataset="ds{{ child_entity_pascal }}" autofittype="col" useinputpanel="true">
{{ child_grid_format | indent(6) }}
    </Grid>
    <Button id="btn_line_add" right="180" top="424" width="80" height="22" text="라인추가" onclick="fn_line_add"/>
    <Button id="btn_line_del" right="90"  top="424" width="80" height="22" text="라인삭제" onclick="fn_line_del"/>

    <!-- Document-level buttons: 하나의 트랜잭션으로 header + lines 저장 -->
    <Button id="btn_new"  right="270" bottom="6" width="80" height="28" text="신규문서" onclick="fn_new_document"/>
    <Button id="btn_del"  right="180" bottom="6" width="80" height="28" text="문서삭제" onclick="fn_delete_document"/>
    <Button id="btn_save" right="90"  bottom="6" width="80" height="28" text="저장"     onclick="fn_save_document"/>
    <Button id="btn_close" right="0"  bottom="6" width="80" height="28" text="닫기"     onclick="fn_close"/>
  </Layout>

  <Objects>
{{ datasets | indent(4) }}
{{ child_datasets | indent(4) }}
  </Objects>

  <Script type="xscript5.1"><![CDATA[
this.fn_search = function() {
  this.transaction("select",
    "Svc{{ service_pascal }}::{{ select_path }}",
    "dsSearch=dsSearch",
    "output1=ds{{ entity_pascal }}",
    "", "fn_callback");
};

this.fn_master_selected = function(obj, e) {
  // header row 변경 → lines 재조회
  var r = this.ds{{ entity_pascal }}.rowposition;
  if (r < 0) return;
  var pk = this.ds{{ entity_pascal }}.getColumn(r, "{{ child_fk_column|default('master_id') }}");
  if (pk === undefined) pk = this.ds{{ entity_pascal }}.getColumn(r, "id");
  this.dsChildSearch.setColumn(0, "{{ child_fk_column|default('master_id') }}", pk);
  this.transaction("select_lines",
    "Svc{{ service_pascal }}::{{ child_select_path }}",
    "dsSearch=dsChildSearch",
    "output1=ds{{ child_entity_pascal }}",
    "", "fn_callback");
};

this.fn_new_document = function() {
  // 새 헤더 row + 라인 데이터셋 초기화
  this.ds{{ entity_pascal }}.clearData();
  this.ds{{ child_entity_pascal }}.clearData();
  this.ds{{ entity_pascal }}.addRow();
};

this.fn_delete_document = function() {
  var r = this.ds{{ entity_pascal }}.rowposition;
  if (r < 0) { alert("삭제할 문서가 없습니다."); return; }
  this.ds{{ entity_pascal }}.deleteRow(r);
  // 연관 라인도 함께 삭제 표시
  for (var i = this.ds{{ child_entity_pascal }}.getRowCountNF() - 1; i >= 0; i--) {
    this.ds{{ child_entity_pascal }}.deleteRow(i);
  }
};

this.fn_line_add = function() {
  if (this.ds{{ entity_pascal }}.getRowCountNF() === 0) {
    alert("먼저 헤더를 생성하세요."); return;
  }
  var nr = this.ds{{ child_entity_pascal }}.addRow();
  // 현재 header 의 PK 를 FK 로 자동 세팅
  var hr = this.ds{{ entity_pascal }}.rowposition;
  var pk = this.ds{{ entity_pascal }}.getColumn(hr, "id");
  if (pk !== undefined) {
    this.ds{{ child_entity_pascal }}.setColumn(nr, "{{ child_fk_column|default('master_id') }}", pk);
  }
};

this.fn_line_del = function() {
  var r = this.ds{{ child_entity_pascal }}.rowposition;
  if (r < 0) return;
  this.ds{{ child_entity_pascal }}.deleteRow(r);
};

this.fn_save_document = function() {
  // header + lines 를 한 transaction 으로 동시 전송 (dataList 콤마 구분)
  if (this.ds{{ entity_pascal }}.getRowCountNF() === 0) {
    alert("저장할 헤더가 없습니다."); return;
  }
  this.transaction("save",
    "Svc{{ service_pascal }}::{{ save_path }}",
    "",
    "",
    "dataList=ds{{ entity_pascal }}:U,dsChildList=ds{{ child_entity_pascal }}:U",
    "fn_callback");
};

this.fn_close = function() {
  if (this.getOwnerFrame) this.getOwnerFrame().close();
};

this.fn_callback = function(svcId, errCd, errMsg) {
  if (errCd < 0) { alert(errMsg); return; }
  if (svcId === "save") {
    alert("저장 완료");
    this.fn_search();
  }
};
  ]]></Script>
</Form>
</FDL>
