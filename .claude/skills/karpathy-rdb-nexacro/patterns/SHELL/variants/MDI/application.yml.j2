server:
  port: 8080
  servlet:
    context-path: /uiadapter

spring:
  datasource:
    url: {{ datasource.url }}
    driver-class-name: {{ datasource.driver_class_name }}
    username: {{ datasource.username }}
    password: "{{ datasource.password }}"
  sql:
    init:
      # always = run schema.sql on every boot (safe for in-memory HSQLDB);
      # embedded = Spring default, runs only on embedded DBs (safe for
      # real Postgres/MySQL — user owns migration with Flyway/Liquibase).
      mode: {{ datasource.init_mode }}
      schema-locations: classpath:schema.sql
      separator: "^^"
      continue-on-error: true
  servlet:
    multipart:
      enabled: true
      max-file-size: 10MB
      max-request-size: 10MB

mybatis:
  mapper-locations: classpath:mybatis/mapper/**/*.xml
  type-aliases-package: {{ target_pkg_prefix }}.{{ domain_slug }}.domain

nexacro:
  file:
    storage-dir: ./uploads

logging:
  level:
    root: INFO
    {{ target_pkg_prefix }}: DEBUG
    org.springframework.jdbc: INFO
    org.mybatis: INFO
