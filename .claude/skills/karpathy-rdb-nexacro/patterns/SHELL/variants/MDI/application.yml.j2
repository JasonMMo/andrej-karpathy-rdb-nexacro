server:
  port: 8080
  servlet:
    context-path: /uiadapter

spring:
  datasource:
    url: jdbc:hsqldb:mem:{{ domain_slug }};sql.syntax_mys=true
    driver-class-name: org.hsqldb.jdbc.JDBCDriver
    username: sa
    password: ""
  sql:
    init:
      mode: always
      schema-locations: classpath:schema.sql
      separator: "^^"
      continue-on-error: true
  servlet:
    multipart:
      enabled: true
      max-file-size: 10MB
      max-request-size: 10MB

mybatis:
  mapper-locations: classpath:mybatis/mapper/**/*.xml
  type-aliases-package: {{ target_pkg_prefix }}.{{ domain_slug }}.domain

nexacro:
  file:
    storage-dir: ./uploads

logging:
  level:
    root: INFO
    {{ target_pkg_prefix }}: DEBUG
    org.springframework.jdbc: INFO
    org.mybatis: INFO
