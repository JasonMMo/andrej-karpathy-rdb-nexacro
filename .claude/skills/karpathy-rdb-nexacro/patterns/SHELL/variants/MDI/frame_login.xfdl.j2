<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.0">
  <Form id="frameLogin" classname="frameLogin" left="0" top="0" width="400" height="{% if auth_mode == 'oauth2' %}380{% else %}280{% endif %}" titletext="{{ login_title | default('로그인') }}">
    <Layouts>
      <Layout>
        <Static id="staTitle" taborder="0" left="0" top="20" width="400" height="32" text="{{ login_title | default('로그인') }}" cssclass="sta_login_title"/>
        <Static id="staIdLbl" taborder="1" left="60" top="80" width="80" height="28" text="ID"/>
        <Edit id="edtId" taborder="2" left="140" top="80" width="200" height="28"/>
        <Static id="staPwLbl" taborder="3" left="60" top="120" width="80" height="28" text="Password"/>
        <Edit id="edtPw" taborder="4" left="140" top="120" width="200" height="28" password="true"/>
        <Button id="btnLogin" taborder="5" left="140" top="180" width="200" height="36" text="로그인"/>
{% if auth_mode == 'oauth2' %}
        <Static id="staOauthLbl" taborder="6" left="60" top="230" width="280" height="20" text="── 또는 ──" textAlign="center"/>
        <Button id="btnLoginGoogle" taborder="7" left="60" top="260" width="140" height="32" text="Google 로그인" cssclass="btn_oauth_google"/>
        <Button id="btnLoginKeycloak" taborder="8" left="200" top="260" width="140" height="32" text="Keycloak SSO" cssclass="btn_oauth_keycloak"/>
{% endif %}
      </Layout>
    </Layouts>
{% if auth_mode == 'none' %}
    <Script type="xscript5.1"><![CDATA[
this.btnLogin_onclick = function(obj, e) {
  var id = this.edtId.value;
  var pw = this.edtPw.value;
  if (!id || !pw) {
    alert("ID/PW를 입력하세요.");
    return;
  }
  var app = nexacro.getApplication();
  app.gv_isLoggedIn = true;
  app.gv_userName = id;
  app.mainframe.closeLoginFrame();
};
]]></Script>
{% else %}
    <Script type="xscript5.1"><![CDATA[
// Growth-21a-3: real /login POST. The backend NexacroAuthenticationFilter
// reads the ds_in DataSet (id/pw/clientId) and replies with a session
// cookie (auth_mode=session) or an Authorization: Bearer header
// (auth_mode={{ auth_mode }}).
this.btnLogin_onclick = function(obj, e) {
  var id = this.edtId.value;
  var pw = this.edtPw.value;
  if (!id || !pw) {
    alert("ID/PW를 입력하세요.");
    return;
  }
  var ds = new nexacro.NormalDataset("ds_in");
  ds.addColumn("id", "string");
  ds.addColumn("pw", "string");
  ds.addColumn("clientId", "string");
  var row = ds.addRow();
  ds.setColumn(row, "id", id);
  ds.setColumn(row, "pw", pw);
  ds.setColumn(row, "clientId", "nexacro-shell");
  this.transaction(
    "login",
    "svc::/login",
    "ds_in=ds_in",
    "",
    "",
    "fn_loginCallback"
  );
  this.ds_in = ds;
};

this.fn_loginCallback = function(svcId, errCd, errMsg) {
  if (errCd !== 0) {
    alert("로그인 실패: " + errMsg);
    return;
  }
{% if auth_mode in ['jwt', 'oauth2'] %}
  // jwt/oauth2: backend SuccessHandler returned a Bearer token in the
  // Authorization header. Stash it on the Application so future
  // transactions add it back as a header.
  var token = this.gfn_getResponseHeader("Authorization");
  if (token) {
    nexacro.getApplication().gv_bearerToken = token;
  }
{% endif %}
  var app = nexacro.getApplication();
  app.gv_isLoggedIn = true;
  app.gv_userName = this.edtId.value;
  app.mainframe.closeLoginFrame();
};
{% if auth_mode == 'oauth2' %}

// Growth-21a-3: OAuth2 redirect-flow. Spring's OAuth2 client serves
// /oauth2/authorization/<provider> which 302s to the IdP; after the
// callback hits /login/oauth2/code/{registrationId} we land back on /.
this.btnLoginGoogle_onclick = function(obj, e) {
  window.location.href = "/uiadapter/oauth2/authorization/google";
};
this.btnLoginKeycloak_onclick = function(obj, e) {
  window.location.href = "/uiadapter/oauth2/authorization/keycloak";
};
{% endif %}
]]></Script>
{% endif %}
  </Form>
</FDL>
