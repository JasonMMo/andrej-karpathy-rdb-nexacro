package {{ target_pkg_prefix }}.{{ domain_slug }}.auth;

import java.io.IOException;

import javax.servlet.ServletException;
import javax.servlet.http.HttpServletRequest;
import javax.servlet.http.HttpServletResponse;

import org.springframework.security.core.AuthenticationException;
import org.springframework.security.web.AuthenticationEntryPoint;
import org.springframework.stereotype.Component;

/**
 * Returns HTTP 401 with a Nexacro-friendly error code so the client can
 * route the user back to the login frame (frameLogin) instead of getting
 * a vanilla login redirect (javax lane — Spring Security 5).
 *
 * Generated by Growth-23 (auth_mode={{ auth_mode }}, auth_lane=javax).
 */
@Component
public class NexacroAuthenticationEntryPoint implements AuthenticationEntryPoint {

    @Override
    public void commence(HttpServletRequest request, HttpServletResponse response,
                         AuthenticationException authException) throws IOException, ServletException {
        response.setStatus(HttpServletResponse.SC_UNAUTHORIZED);
        response.setHeader("X-Auth-Error", "UNAUTHENTICATED");
        response.setContentType("application/json;charset=UTF-8");
        response.getWriter().write("{\"ErrorCode\":-1,\"ErrorMsg\":\"Authentication required\"}");
    }
}
