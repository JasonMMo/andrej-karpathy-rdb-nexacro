package {{ target_pkg_prefix }}.{{ domain_slug }}.auth;

import java.io.IOException;
{% if auth_mode in ['jwt', 'oauth2'] %}
import java.util.stream.Collectors;
{% endif %}

import javax.servlet.ServletException;
import javax.servlet.http.HttpServletRequest;
import javax.servlet.http.HttpServletResponse;

{% if auth_mode in ['jwt', 'oauth2'] %}
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.security.core.GrantedAuthority;
{% endif %}
import org.springframework.security.core.Authentication;
import org.springframework.security.web.authentication.AuthenticationSuccessHandler;
import org.springframework.stereotype.Component;

/**
 * Writes a JSON success payload to the Nexacro client (javax lane —
 * Spring Security 5). When auth_mode is {@code jwt} or {@code oauth2} the
 * issued bearer token is added to the {@code Authorization} response header
 * so the client can attach it to subsequent service calls.
 *
 * Generated by Growth-23 (auth_mode={{ auth_mode }}, auth_lane=javax).
 */
@Component
public class NexacroAuthenticationSuccessHandler implements AuthenticationSuccessHandler {

{% if auth_mode in ['jwt', 'oauth2'] %}
    @Autowired
    private JwtTokenProvider jwtTokenProvider;
{% endif %}

    @Override
    public void onAuthenticationSuccess(HttpServletRequest request, HttpServletResponse response,
                                        Authentication authentication) throws IOException, ServletException {
        response.setStatus(HttpServletResponse.SC_OK);
        response.setContentType("application/json;charset=UTF-8");

{% if auth_mode in ['jwt', 'oauth2'] %}
        String roles = authentication.getAuthorities().stream()
                .map(GrantedAuthority::getAuthority)
                .collect(Collectors.joining(","));
        String token = jwtTokenProvider.issue(authentication.getName(), roles);
        response.setHeader("Authorization", "Bearer " + token);
        response.getWriter().write(
                "{\"ErrorCode\":0,\"ErrorMsg\":\"OK\",\"user\":\"" + authentication.getName() + "\"}");
{% else %}
        response.getWriter().write(
                "{\"ErrorCode\":0,\"ErrorMsg\":\"OK\",\"user\":\"" + authentication.getName() + "\"}");
{% endif %}
    }
}
