import java.io.IOException;
import java.util.Map;

import jakarta.servlet.FilterChain;
import jakarta.servlet.ServletException;
import jakarta.servlet.http.HttpServletRequest;
import jakarta.servlet.http.HttpServletResponse;

import org.springframework.security.authentication.AuthenticationServiceException;
import org.springframework.security.core.Authentication;
import org.springframework.security.core.AuthenticationException;
import org.springframework.security.web.authentication.AbstractAuthenticationProcessingFilter;
import org.springframework.security.web.util.matcher.AntPathRequestMatcher;

import com.nexacro.uiadapter6.spring.core.data.NexacroFileResult;
import com.nexacro.uiadapter6.spring.core.servlet.NexacroController;
import com.nexacro.uiadapter6.spring.core.servlet.NexacroRequestParser;
import com.nexacro.uiadapter6.spring.core.servlet.NexacroResultWriter;
import com.nexacro.xapi.data.DataSet;
import com.nexacro.xapi.data.PlatformData;

/**
 * Authentication filter that parses a Nexacro DataSet payload from the login
 * POST and dispatches it to {@link NexacroAuthenticationProvider}.
 *
 * Expected input dataset name: {@code ds_in} with columns:
 *   id (string), pw (string), clientId (string, optional)
 *
 * Generated by Growth-21a-2 (auth_mode={{ auth_mode }}).
 */
public class NexacroAuthenticationFilter extends AbstractAuthenticationProcessingFilter {

    private static final String DEFAULT_LOGIN_URL = "/login";
    private static final String IN_DATASET = "ds_in";

    public NexacroAuthenticationFilter() {
        super(new AntPathRequestMatcher(DEFAULT_LOGIN_URL, "POST"));
    }

    @Override
    public Authentication attemptAuthentication(HttpServletRequest request, HttpServletResponse response)
            throws AuthenticationException, IOException, ServletException {

        if (!"POST".equalsIgnoreCase(request.getMethod())) {
            throw new AuthenticationServiceException("Authentication method not supported: " + request.getMethod());
        }

        PlatformData input;
        try {
            input = NexacroRequestParser.parsePlatformData(request);
        } catch (Exception ex) {
            throw new AuthenticationServiceException("Cannot parse Nexacro login payload", ex);
        }

        DataSet ds = input.getDataSet(IN_DATASET);
        if (ds == null || ds.getRowCount() == 0) {
            throw new AuthenticationServiceException("Missing dataset '" + IN_DATASET + "' in login request");
        }

        String id = nullSafe(ds.getString(0, "id"));
        String pw = nullSafe(ds.getString(0, "pw"));
        String clientId = nullSafe(ds.getString(0, "clientId"));

        NexacroAuthenticationToken token = new NexacroAuthenticationToken(id, pw, clientId);
        setDetails(request, token);
        return this.getAuthenticationManager().authenticate(token);
    }

    private void setDetails(HttpServletRequest request, NexacroAuthenticationToken token) {
        token.setDetails(this.authenticationDetailsSource.buildDetails(request));
    }

    private static String nullSafe(String s) {
        return s == null ? "" : s;
    }
}
