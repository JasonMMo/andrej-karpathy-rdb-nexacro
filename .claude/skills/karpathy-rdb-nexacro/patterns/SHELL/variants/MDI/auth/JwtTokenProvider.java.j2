package {{ target_pkg_prefix }}.{{ domain_slug }}.auth;

import java.nio.charset.StandardCharsets;
import java.util.Date;

import jakarta.annotation.PostConstruct;

import org.springframework.beans.factory.annotation.Value;
import org.springframework.stereotype.Component;

import io.jsonwebtoken.Claims;
import io.jsonwebtoken.JwtException;
import io.jsonwebtoken.Jws;
import io.jsonwebtoken.Jwts;
import io.jsonwebtoken.SignatureAlgorithm;
import io.jsonwebtoken.security.Keys;

import javax.crypto.SecretKey;

/**
 * HMAC-SHA256 JWT provider. Wired only when auth_mode is {@code jwt} or
 * {@code oauth2}. Pair with {@code refresh_token} entity from the 권한관리
 * seed for rotation — this class issues only the access token; the refresh
 * flow lives in your service layer.
 *
 * Generated by Growth-21a-2 (auth_mode={{ auth_mode }}).
 */
@Component
public class JwtTokenProvider {

    @Value("${app.security.jwt.secret:change-me-please-please-change-me-32b}")
    private String secret;

    @Value("${app.security.jwt.ttl-seconds:1800}")
    private long ttlSeconds;

    @Value("${app.security.jwt.issuer:{{ domain_slug }}-shell}")
    private String issuer;

    private SecretKey key;

    @PostConstruct
    void init() {
        byte[] bytes = secret.getBytes(StandardCharsets.UTF_8);
        if (bytes.length < 32) {
            byte[] padded = new byte[32];
            System.arraycopy(bytes, 0, padded, 0, bytes.length);
            bytes = padded;
        }
        this.key = Keys.hmacShaKeyFor(bytes);
    }

    public String issue(String subject, String rolesCsv) {
        long nowMs = System.currentTimeMillis();
        return Jwts.builder()
                .setSubject(subject)
                .claim("roles", rolesCsv == null ? "" : rolesCsv)
                .setIssuer(issuer)
                .setIssuedAt(new Date(nowMs))
                .setExpiration(new Date(nowMs + ttlSeconds * 1000L))
                .signWith(key, SignatureAlgorithm.HS256)
                .compact();
    }

    public Claims parse(String token) throws JwtException {
        Jws<Claims> jws = Jwts.parserBuilder()
                .setSigningKey(key)
                .requireIssuer(issuer)
                .build()
                .parseClaimsJws(token);
        return jws.getBody();
    }

    public boolean isValid(String token) {
        try {
            parse(token);
            return true;
        } catch (JwtException ex) {
            return false;
        }
    }
}
