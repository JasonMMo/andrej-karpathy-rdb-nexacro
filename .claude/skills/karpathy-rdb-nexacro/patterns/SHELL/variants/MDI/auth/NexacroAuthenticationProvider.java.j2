package {{ target_pkg_prefix }}.{{ domain_slug }}.auth;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.security.authentication.AuthenticationProvider;
import org.springframework.security.authentication.BadCredentialsException;
import org.springframework.security.core.Authentication;
import org.springframework.security.core.AuthenticationException;
import org.springframework.security.core.userdetails.UserDetails;
import org.springframework.security.crypto.password.PasswordEncoder;
import org.springframework.stereotype.Component;

/**
 * Validates {@link NexacroAuthenticationToken} against the local
 * {@link NexacroUserDetailsService} (which reads from the 권한관리
 * tables: app_user / role / user_role / role_permission).
 *
 * Generated by Growth-21a-2 (auth_mode={{ auth_mode }}).
 */
@Component
public class NexacroAuthenticationProvider implements AuthenticationProvider {

    @Autowired
    private NexacroUserDetailsService userDetailsService;

    @Autowired
    private PasswordEncoder passwordEncoder;

    @Override
    public Authentication authenticate(Authentication authentication) throws AuthenticationException {
        NexacroAuthenticationToken token = (NexacroAuthenticationToken) authentication;
        String loginId = String.valueOf(token.getPrincipal());
        String rawPw = String.valueOf(token.getCredentials());

        UserDetails user = userDetailsService.loadUserByUsername(loginId);
        if (user == null || !passwordEncoder.matches(rawPw, user.getPassword())) {
            throw new BadCredentialsException("Invalid login id or password");
        }
        if (!user.isEnabled()) {
            throw new BadCredentialsException("User is disabled");
        }

        NexacroAuthenticationToken authed = new NexacroAuthenticationToken(
                user, null, user.getAuthorities(), token.getClientId());
        authed.setDetails(token.getDetails());
        return authed;
    }

    @Override
    public boolean supports(Class<?> authentication) {
        return NexacroAuthenticationToken.class.isAssignableFrom(authentication);
    }
}
