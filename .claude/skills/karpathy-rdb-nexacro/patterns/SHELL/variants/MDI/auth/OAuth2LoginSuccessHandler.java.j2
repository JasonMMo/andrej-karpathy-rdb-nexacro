package {{ target_pkg_prefix }}.{{ domain_slug }}.auth;

import java.io.IOException;
import java.time.OffsetDateTime;

import jakarta.servlet.ServletException;
import jakarta.servlet.http.HttpServletRequest;
import jakarta.servlet.http.HttpServletResponse;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.jdbc.core.JdbcTemplate;
import org.springframework.security.core.Authentication;
import org.springframework.security.oauth2.core.user.OAuth2User;
import org.springframework.security.web.authentication.SimpleUrlAuthenticationSuccessHandler;
import org.springframework.stereotype.Component;

/**
 * OAuth2 redirect-flow landing handler. Spring's OAuth2 client lands here
 * after the IdP callback (/login/oauth2/code/{registrationId}).
 *
 * Responsibilities:
 *  1. Resolve the federated identity → local app_user via the
 *     oauth_account table (provider + provider_user_id).
 *  2. Auto-provision the link row on first sight (just-in-time).
 *  3. Issue an access JWT using the same {@link JwtTokenProvider} the
 *     password flow uses, so the rest of the app treats both identically.
 *  4. Redirect back to the SPA root (the Nexacro shell), with the token
 *     attached to a short-lived cookie the frame_login script picks up.
 *
 * Generated by Growth-21a-3 (auth_mode={{ auth_mode }}).
 */
@Component
public class OAuth2LoginSuccessHandler extends SimpleUrlAuthenticationSuccessHandler {

    @Autowired
    private JdbcTemplate jdbc;
    @Autowired
    private JwtTokenProvider jwtTokenProvider;

    @Override
    public void onAuthenticationSuccess(HttpServletRequest request,
                                        HttpServletResponse response,
                                        Authentication authentication)
            throws IOException, ServletException {

        String registrationId = extractRegistrationId(request);
        OAuth2User principal = (OAuth2User) authentication.getPrincipal();
        String providerUserId = String.valueOf(principal.getAttributes().getOrDefault("sub",
                principal.getName()));
        String email = (String) principal.getAttributes().get("email");
        String displayName = (String) principal.getAttributes().getOrDefault("name", email);

        Long userId = resolveOrProvision(registrationId, providerUserId, email, displayName);
        String roles = jdbc.queryForObject(
                "SELECT COALESCE(STRING_AGG(r.code, ','), '') " +
                "FROM user_role ur JOIN role r ON r.id = ur.role_id WHERE ur.user_id = ?",
                String.class, userId);

        String token = jwtTokenProvider.issue(String.valueOf(userId), roles);
        response.setHeader("Authorization", "Bearer " + token);
        // Short-lived cookie so the SPA can read the token after redirect.
        response.addHeader("Set-Cookie",
                "X-Auth-Bearer=" + token + "; Path=/; Max-Age=60; SameSite=Lax");

        getRedirectStrategy().sendRedirect(request, response, "/");
    }

    private String extractRegistrationId(HttpServletRequest request) {
        String uri = request.getRequestURI();
        int idx = uri.lastIndexOf('/');
        return idx >= 0 ? uri.substring(idx + 1) : uri;
    }

    private Long resolveOrProvision(String provider, String providerUserId,
                                    String email, String displayName) {
        // Lookup existing link.
        Long userId = jdbc.query(
                "SELECT user_id FROM oauth_account WHERE provider = ? AND provider_user_id = ?",
                rs -> rs.next() ? rs.getLong(1) : null,
                provider, providerUserId);
        if (userId != null) {
            return userId;
        }

        // Auto-provision: create app_user (if email is new) + oauth_account row.
        Long resolved = jdbc.query(
                "SELECT id FROM app_user WHERE email = ?",
                rs -> rs.next() ? rs.getLong(1) : null, email);
        if (resolved == null) {
            jdbc.update(
                "INSERT INTO app_user(username, email, display_name, status, created_at) " +
                "VALUES (?, ?, ?, 'ACTIVE', ?)",
                providerUserId, email, displayName, OffsetDateTime.now());
            resolved = jdbc.queryForObject(
                "SELECT id FROM app_user WHERE email = ?", Long.class, email);
        }
        jdbc.update(
            "INSERT INTO oauth_account(user_id, provider, provider_user_id, linked_at) " +
            "VALUES (?, ?, ?, ?)",
            resolved, provider, providerUserId, OffsetDateTime.now());
        return resolved;
    }
}
