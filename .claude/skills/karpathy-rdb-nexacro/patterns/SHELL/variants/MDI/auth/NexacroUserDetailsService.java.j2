package {{ target_pkg_prefix }}.{{ domain_slug }}.auth;

import java.util.ArrayList;
import java.util.List;

import javax.sql.DataSource;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.jdbc.core.JdbcTemplate;
import org.springframework.security.core.GrantedAuthority;
import org.springframework.security.core.authority.SimpleGrantedAuthority;
import org.springframework.security.core.userdetails.User;
import org.springframework.security.core.userdetails.UserDetails;
import org.springframework.security.core.userdetails.UserDetailsService;
import org.springframework.security.core.userdetails.UsernameNotFoundException;
import org.springframework.stereotype.Service;

/**
 * Loads users + their granted role codes directly from the 권한관리 tables
 * (app_user / user_role / role) using JdbcTemplate. Lean by design — no
 * extra service layer, no caching. Wire up your own caching layer
 * (Caffeine, Redis) at the Provider/Filter level once you measure load.
 *
 * Generated by Growth-21a-2 (auth_mode={{ auth_mode }}).
 */
@Service
public class NexacroUserDetailsService implements UserDetailsService {

    private final JdbcTemplate jdbc;

    @Autowired
    public NexacroUserDetailsService(DataSource dataSource) {
        this.jdbc = new JdbcTemplate(dataSource);
    }

    @Override
    public UserDetails loadUserByUsername(String loginId) throws UsernameNotFoundException {
        List<UserRow> rows = jdbc.query(
                "SELECT login_id, password_hash, is_active FROM app_user WHERE login_id = ?",
                (rs, n) -> new UserRow(
                        rs.getString("login_id"),
                        rs.getString("password_hash"),
                        rs.getBoolean("is_active")),
                loginId);
        if (rows.isEmpty()) {
            throw new UsernameNotFoundException("No user with login_id=" + loginId);
        }
        UserRow row = rows.get(0);

        List<String> roleCodes = jdbc.queryForList(
                "SELECT r.code FROM app_user u "
              + "JOIN user_role ur ON ur.user_id = u.id "
              + "JOIN role r ON r.id = ur.role_id "
              + "WHERE u.login_id = ?",
                String.class, loginId);

        List<GrantedAuthority> authorities = new ArrayList<>();
        for (String code : roleCodes) {
            authorities.add(new SimpleGrantedAuthority("ROLE_" + code));
        }

        return User.withUsername(row.loginId)
                .password(row.passwordHash)
                .disabled(!row.isActive)
                .authorities(authorities)
                .build();
    }

    private static final class UserRow {
        final String loginId;
        final String passwordHash;
        final boolean isActive;
        UserRow(String loginId, String passwordHash, boolean isActive) {
            this.loginId = loginId;
            this.passwordHash = passwordHash;
            this.isActive = isActive;
        }
    }
}
