package {{ target_pkg_prefix }}.{{ domain_slug }}.auth;

import jakarta.servlet.http.HttpServletRequest;

import org.springframework.security.authentication.AuthenticationDetailsSource;
import org.springframework.security.web.authentication.WebAuthenticationDetails;

/**
 * Captures the request's remote IP + session id alongside the auth attempt
 * so {@link NexacroAuthenticationProvider} and audit hooks can record the
 * full context (matches the login_audit entity from the 권한관리 seed —
 * ip_address / occurred_at columns).
 *
 * Generated by Growth-21a-2 (auth_mode={{ auth_mode }}).
 */
public class NexacroAuthenticationDetailSource
        implements AuthenticationDetailsSource<HttpServletRequest, WebAuthenticationDetails> {

    @Override
    public WebAuthenticationDetails buildDetails(HttpServletRequest context) {
        return new WebAuthenticationDetails(context);
    }
}
