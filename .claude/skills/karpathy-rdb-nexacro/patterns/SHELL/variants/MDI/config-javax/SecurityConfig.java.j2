package {{ target_pkg_prefix }}.{{ domain_slug }}.config;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.context.annotation.Bean;
import org.springframework.context.annotation.Configuration;
import org.springframework.security.authentication.AuthenticationManager;
import org.springframework.security.config.annotation.authentication.builders.AuthenticationManagerBuilder;
import org.springframework.security.config.annotation.web.builders.HttpSecurity;
import org.springframework.security.config.annotation.web.configuration.EnableWebSecurity;
import org.springframework.security.config.annotation.web.configuration.WebSecurityConfigurerAdapter;
import org.springframework.security.config.http.SessionCreationPolicy;
import org.springframework.security.crypto.bcrypt.BCryptPasswordEncoder;
import org.springframework.security.crypto.password.PasswordEncoder;
import org.springframework.security.web.authentication.UsernamePasswordAuthenticationFilter;

import {{ target_pkg_prefix }}.{{ domain_slug }}.auth.NexacroAccessDeniedHandler;
import {{ target_pkg_prefix }}.{{ domain_slug }}.auth.NexacroAuthenticationDetailSource;
import {{ target_pkg_prefix }}.{{ domain_slug }}.auth.NexacroAuthenticationEntryPoint;
import {{ target_pkg_prefix }}.{{ domain_slug }}.auth.NexacroAuthenticationFailureHandler;
import {{ target_pkg_prefix }}.{{ domain_slug }}.auth.NexacroAuthenticationFilter;
import {{ target_pkg_prefix }}.{{ domain_slug }}.auth.NexacroAuthenticationProvider;
import {{ target_pkg_prefix }}.{{ domain_slug }}.auth.NexacroAuthenticationSuccessHandler;
{% if auth_mode == 'oauth2' %}
import {{ target_pkg_prefix }}.{{ domain_slug }}.auth.OAuth2LoginSuccessHandler;
{% endif %}

/**
 * Spring Security 5 configuration for the Nexacro DataSet auth flow
 * (javax lane — WebSecurityConfigurerAdapter pattern).
 *
 * Session policy depends on auth_mode:
 *   - session : IF_REQUIRED (default cookie-backed JSESSIONID)
 *   - jwt     : STATELESS  (each request carries Bearer token)
 *   - oauth2  : STATELESS  (same as jwt; OAuth2 client wired below)
 *
 * Generated by Growth-23 (auth_mode={{ auth_mode }}, auth_lane=javax).
 */
@Configuration
@EnableWebSecurity
public class SecurityConfig extends WebSecurityConfigurerAdapter {

    @Autowired
    private NexacroAuthenticationProvider authProvider;
    @Autowired
    private NexacroAuthenticationEntryPoint entryPoint;
    @Autowired
    private NexacroAccessDeniedHandler accessDeniedHandler;
    @Autowired
    private NexacroAuthenticationSuccessHandler successHandler;
    @Autowired
    private NexacroAuthenticationFailureHandler failureHandler;
{% if auth_mode == 'oauth2' %}
    @Autowired
    private OAuth2LoginSuccessHandler oauth2SuccessHandler;
{% endif %}

    @Bean
    public PasswordEncoder passwordEncoder() {
        return new BCryptPasswordEncoder();
    }

    @Override
    protected void configure(AuthenticationManagerBuilder auth) throws Exception {
        auth.authenticationProvider(authProvider);
    }

    @Bean
    @Override
    public AuthenticationManager authenticationManagerBean() throws Exception {
        return super.authenticationManagerBean();
    }

    @Bean
    public NexacroAuthenticationFilter nexacroAuthenticationFilter() throws Exception {
        NexacroAuthenticationFilter f = new NexacroAuthenticationFilter();
        f.setAuthenticationManager(authenticationManagerBean());
        f.setAuthenticationDetailsSource(new NexacroAuthenticationDetailSource());
        f.setAuthenticationSuccessHandler(successHandler);
        f.setAuthenticationFailureHandler(failureHandler);
        return f;
    }

    @Override
    protected void configure(HttpSecurity http) throws Exception {
        http
            .csrf().disable()
            .formLogin().disable()
            .httpBasic().disable()
            .sessionManagement()
                .sessionCreationPolicy(
{% if auth_mode in ['jwt', 'oauth2'] %}
                    SessionCreationPolicy.STATELESS
{% else %}
                    SessionCreationPolicy.IF_REQUIRED
{% endif %}
                )
                .and()
            .exceptionHandling()
                .authenticationEntryPoint(entryPoint)
                .accessDeniedHandler(accessDeniedHandler)
                .and()
            .authorizeRequests()
                .antMatchers("/login", "/error", "/actuator/health").permitAll()
                .antMatchers("/nxui/**", "/static/**").permitAll()
{% if auth_mode == 'oauth2' %}
                .antMatchers("/oauth2/**", "/login/oauth2/**").permitAll()
{% endif %}
                .anyRequest().authenticated()
                .and()
            .addFilterBefore(nexacroAuthenticationFilter(),
                    UsernamePasswordAuthenticationFilter.class);
{% if auth_mode == 'oauth2' %}

        // Growth-23 (javax lane): enable OAuth2 client login flow alongside
        // the Nexacro password filter. Spring serves the authorization
        // request at /oauth2/authorization/{registrationId} and lands on
        // /login/oauth2/code/{registrationId} after the IdP callback.
        http.oauth2Login()
                .successHandler(oauth2SuccessHandler);
{% endif %}
    }
}
