<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.0">
<Form id="{{ form_id }}" width="900" height="640" titletext="{{ title }}">
  <Layout>
    <!-- Search panel (top) -->
    <Static id="ttl_search" left="10" top="6" width="120" height="20" text="검색조건" cssclass="sta_WF_Title"/>
    {{ search_fields | indent(4) }}
    <Button id="btn_search" left="310" top="20" width="80" height="24" text="조회" onclick="fn_search"/>

    <!-- Master area (top, 60..280): single record edit bound to ds{{ entity_pascal }} rowposition -->
    <Static id="ttl_master" left="10" top="60" width="120" height="20" text="마스터" cssclass="sta_WF_Title"/>
    <Grid id="grd_master" left="10" top="90" width="880" height="180"
          binddataset="ds{{ entity_pascal }}" autofittype="col" useinputpanel="true"
          oncellclick="fn_master_changed">
{{ grid_format | indent(6) }}
    </Grid>
    <Button id="btn_add"  left="710" top="280" width="80" height="24" text="추가" onclick="fn_add_master"/>
    <Button id="btn_del"  left="800" top="280" width="80" height="24" text="삭제" onclick="fn_delete_master"/>

    <!-- Divider -->
    <Static id="div_h" left="10" top="310" width="880" height="1" cssclass="sta_WF_Divider"/>

    <!-- Child area (bottom, 320..600): line items grid bound to ds{{ child_entity_pascal|default('Child') }} -->
    {% if child_entity_pascal %}
    <Static id="ttl_child" left="10" top="320" width="200" height="20" text="라인 아이템 ({{ child_entity_name }})" cssclass="sta_WF_Title"/>
    <Grid id="grd_child" left="10" top="346" width="880" height="240"
          binddataset="ds{{ child_entity_pascal }}" autofittype="col" useinputpanel="true">
{{ child_grid_format | indent(6) }}
    </Grid>
    <Button id="btn_child_add" left="620" top="600" width="80" height="28" text="라인 추가" onclick="fn_add_child"/>
    <Button id="btn_child_del" left="710" top="600" width="80" height="28" text="라인 삭제" onclick="fn_delete_child"/>
    {% else %}
    <Static id="ttl_child" left="10" top="320" width="200" height="20" text="라인 아이템" cssclass="sta_WF_Title"/>
    <Static id="hint_child" left="220" top="320" width="670" height="20"
            text="(blueprint relations에 1:N child가 없어 라인 영역은 비어있습니다 — concept 추가 권장)"
            cssclass="sta_WF_Hint"/>
    {% endif %}
    <Button id="btn_save" left="800" top="600" width="80" height="28" text="저장" onclick="fn_save"/>
  </Layout>

  <Objects>
{{ datasets | indent(4) }}
{% if child_datasets %}
{{ child_datasets | indent(4) }}
{% endif %}
  </Objects>

  <Script type="xscript5.1"><![CDATA[
this.fn_search = function() {
  this.transaction("select",
    "Svc{{ service_pascal }}::{{ select_path }}",
    "dsSearch=dsSearch",
    "output1=ds{{ entity_pascal }}",
    "", "fn_callback");
};

this.fn_master_changed = function(obj, e) {
{% if child_entity_pascal and child_select_path %}
  // 부모 행 변경 시 자식 dataset 재조회
  var r = this.ds{{ entity_pascal }}.rowposition;
  if (r < 0) return;
  var pk = this.ds{{ entity_pascal }}.getColumn(r, "id");
  this.dsSearch.setColumn(0, "{{ child_fk_column|default('parent_id') }}", pk);
  this.transaction("select_child",
    "Svc{{ service_pascal }}::{{ child_select_path }}",
    "dsSearch=dsSearch",
    "output1=ds{{ child_entity_pascal }}",
    "", "fn_callback");
{% endif %}
};

this.fn_add_master = function() {
  this.ds{{ entity_pascal }}.addRow();
};

this.fn_delete_master = function() {
  var r = this.ds{{ entity_pascal }}.rowposition;
  if (r < 0) return;
  this.ds{{ entity_pascal }}.deleteRow(r);
};

{% if child_entity_pascal %}
this.fn_add_child = function() {
  var r = this.ds{{ entity_pascal }}.rowposition;
  if (r < 0) { alert("먼저 마스터 행을 선택하세요."); return; }
  var nr = this.ds{{ child_entity_pascal }}.addRow();
  var pk = this.ds{{ entity_pascal }}.getColumn(r, "id");
  this.ds{{ child_entity_pascal }}.setColumn(nr, "{{ child_fk_column|default('parent_id') }}", pk);
};

this.fn_delete_child = function() {
  var r = this.ds{{ child_entity_pascal }}.rowposition;
  if (r < 0) return;
  this.ds{{ child_entity_pascal }}.deleteRow(r);
};
{% endif %}

this.fn_save = function() {
  if (this.ds{{ entity_pascal }}.getRowCountNF() === 0) {
    alert("저장할 마스터가 없습니다.");
    return;
  }
  this.transaction("save",
    "Svc{{ service_pascal }}::{{ save_path }}",
    "",
    "",
{% if child_entity_pascal %}
    "dataList=ds{{ entity_pascal }}:U childList=ds{{ child_entity_pascal }}:U",
{% else %}
    "dataList=ds{{ entity_pascal }}:U",
{% endif %}
    "fn_callback");
};

this.fn_callback = function(svcId, errCd, errMsg) {
  if (errCd < 0) { alert(errMsg); return; }
  if (svcId === "save") this.fn_search();
};
  ]]></Script>
</Form>
</FDL>
