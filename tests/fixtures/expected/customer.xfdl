<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.0">
<Form id="customer" width="900" height="620" titletext="Customer 관리">
  <Layout>
    <!-- Search panel (top, 60px) -->
    <Static id="ttl_search" left="10" top="6" width="120" height="20" text="검색조건" cssclass="sta_WF_Title"/>
    <Static id="stt_customer_id" text="Customer Id" left="140" top="20" width="80" height="24"/>
    <Edit id="edt_customer_id" left="224" top="20" width="160" height="24"/>
    <Static id="stt_name" text="Name" left="400" top="20" width="80" height="24"/>
    <Edit id="edt_name" left="484" top="20" width="160" height="24"/>
    <Static id="stt_active_yn" text="Active Yn" left="660" top="20" width="80" height="24"/>
    <Combo id="cmb_active_yn" left="744" top="20" width="120" height="24" innerdataset="ds_active_yn_codes" codecolumn="code" datacolumn="name"/>
    <Static id="stt_created_at" text="Created At" left="920" top="20" width="80" height="24"/>
    <Calendar id="cal_created_at" left="1004" top="20" width="120" height="24"/>
    <Button id="btn_search" left="780" top="20" width="80" height="24" text="조회" onclick="fn_search"/>

    <!-- Grid (middle, 520px) -->
    <Grid id="grd_main" left="10" top="70" width="880" height="500"
          binddataset="dsCustomer" autofittype="col" useinputpanel="false">
<Format id="default">
        <Columns>    <Column size="36"/>    <Column size="100"/>    <Column size="200"/>    <Column size="1"/>    <Column size="14"/>  </Columns>
        <Rows>
          <Row size="24" band="head"/>
          <Row size="24"/>
        </Rows>
        <Band id="head">    <Cell col="0" text="Customer Id"/>    <Cell col="1" text="Name"/>    <Cell col="2" text="Email"/>    <Cell col="3" text="Active Yn"/>    <Cell col="4" text="Created At"/>  </Band>
        <Band id="body">    <Cell col="0" text="bind:customer_id" edittype="none" displaytype="text"/>    <Cell col="1" text="bind:name" edittype="text" displaytype="text"/>    <Cell col="2" text="bind:email" edittype="text" displaytype="text"/>    <Cell col="3" text="bind:active_yn" edittype="combo" displaytype="combotext"/>    <Cell col="4" text="bind:created_at" edittype="date" displaytype="date"/>  </Band>
      </Format>
    </Grid>

    <!-- Action buttons (bottom) -->
    <Button id="btn_add"  left="620" top="580" width="80" height="28" text="추가"   onclick="fn_add"/>
    <Button id="btn_del"  left="710" top="580" width="80" height="28" text="삭제"   onclick="fn_delete"/>
    <Button id="btn_save" left="800" top="580" width="80" height="28" text="저장"   onclick="fn_save"/>
  </Layout>

  <Objects>
<Dataset id="dsSearch">
      <ColumnInfo>    <Column id="customer_id" type="STRING" size="36"/>    <Column id="name" type="STRING" size="100"/>    <Column id="active_yn" type="STRING" size="1"/>    <Column id="created_at" type="STRING" size="14"/>  </ColumnInfo></Dataset>
    <Dataset id="dsCustomer">
      <ColumnInfo>    <Column id="customer_id" type="STRING" size="36"/>    <Column id="name" type="STRING" size="100"/>    <Column id="email" type="STRING" size="200"/>    <Column id="active_yn" type="STRING" size="1"/>    <Column id="created_at" type="STRING" size="14"/>  </ColumnInfo></Dataset>
  </Objects>

  <Script type="xscript5.1"><![CDATA[
this.fn_search = function() {
  this.transaction("select",
    "SvcDefault::/customer/select_datalist_map.do",
    "dsSearch=dsSearch",
    "output1=dsCustomer",
    "", "fn_callback");
};

this.fn_add = function() {
  var n = this.dsCustomer.addRow();
  this.grd_main.setCellPos(0);
};

this.fn_delete = function() {
  var r = this.dsCustomer.rowposition;
  if (r < 0) return;
  this.dsCustomer.deleteRow(r);
};

this.fn_save = function() {
  if (this.dsCustomer.getRowCountNF() === 0) {
    alert("저장할 행이 없습니다.");
    return;
  }
  this.transaction("save",
    "SvcDefault::/customer/save_datalist_map.do",
    "",
    "",
    "dataList=dsCustomer:U",
    "fn_callback");
};

this.fn_callback = function(svcId, errCd, errMsg) {
  if (errCd < 0) { alert(errMsg); return; }
  if (svcId === "save") this.fn_search();
};
  ]]></Script>
</Form>
</FDL>